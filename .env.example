# App
APP_ENV=local

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# DuckDB
DUCKDB_PATH=./data/analytics.duckdb

# AWS / S3
AWS_REGION=us-east-1
S3_BUCKET=
S3_PREFIX=redshift-streaming-analytics

# Redshift
REDSHIFT_HOST=
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=dev
REDSHIFT_USER=
REDSHIFT_PASSWORD=
REDSHIFT_SCHEMA=public
REDSHIFT_EVENTS_TABLE=query_metrics
REDSHIFT_IAM_ROLE=
